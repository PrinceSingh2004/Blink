# ═══════════════════════════════════════════════════════════
# Blink – Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (MySQL) ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=blink_app
DB_SSL=false

# ── Auth (JWT) ──────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRES=7d

# ── Email (for OTP / password reset) ────────────────────────
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_password_here

# ── CORS / Frontend origin ─────────────────────────────────
# Set to your Render URL in production (e.g., https://blink-abc123.onrender.com)
CLIENT_URL=http://localhost:4000

# ── Cloudinary (Image Hosting) ──────────────────────────────
# Get these from: https://console.cloudinary.com/settings/api-keys
CLOUD_NAME=
API_KEY=
API_SECRET=
# Alternative naming (both supported):
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
