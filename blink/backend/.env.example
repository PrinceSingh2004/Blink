# ── Blink – Backend Environment Template ─────────────────
# Copy this to .env and fill in your actual credentials.

# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (MySQL) ────────────────────────────────────
# Use a cloud MySQL host like PlanetScale, Railway, or Aiven for production.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=blink_app

# ── Authentication ──────────────────────────────────────
# Generate a strong 32+ character random string for production.
JWT_SECRET=blink_jwt_super_secret_key_2024_CHANGE_IN_PROD
JWT_EXPIRES=7d

# ── Email (for OTP / password reset) ────────────────────
# Use a Gmail address and an App Password.
EMAIL_USER=
EMAIL_PASS=

# ── CORS / Frontend origin ──────────────────────────────
# Set to your Render web service URL in production.
CLIENT_URL=http://localhost:4000
